{
  "info": {
    "_postman_id": "ab89a611-aa8d-4d7a-a01e-f4a407023a45",
    "name": "SqlSanitizer API",
    "description": "API collection for SQL Sanitization and Sensitive Word Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "30439970"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "    console.log(\"Token saved:\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": {{username}},\n  \"password\": {{password}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v{{apiVersion}}/Auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v{{apiVersion}}",
                "Auth",
                "login"
              ]
            },
            "description": "Authenticates a user and returns a JWT token. The token is automatically saved to the collection variable for use in subsequent requests."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints for obtaining JWT tokens"
    },
    {
      "name": "Sanitization",
      "item": [
        {
          "name": "Sanitize SQL Query",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"SELECT * FROM Users WHERE username = 'admin' AND password = 'secret'\""
            },
            "url": {
              "raw": "{{baseUrl}}/api/v{{apiVersion}}/Sanitize/sanitize",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v{{apiVersion}}",
                "Sanitize",
                "sanitize"
              ]
            },
            "description": "Sanitizes a SQL query by removing or masking sensitive words. Requires authentication."
          },
          "response": []
        }
      ],
      "description": "SQL query sanitization endpoints"
    },
    {
